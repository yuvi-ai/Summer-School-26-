#include <WiFi.h>
#include <HTTPClient.h>
#include <ArduinoJson.h>
#include <DHT.h>

// DHT11 Local Sensor Configuration
#define DHTPIN 5         // GPIO pin connected to the DHT11 data pin
#define DHTTYPE DHT11
DHT dht(DHTPIN, DHTTYPE);

// Timing variable for fetching API data every 10 minutes (free tier friendly)
unsigned long lastTime = 0;
unsigned long timerDelay = 1000; // 10 minutes in milliseconds

void setup() {
  Serial.begin(115200);
  
  // Initialize DHT11 sensor
  dht.begin();

  // Connect to Wi-Fi
  Serial.print("Connecting to WiFi");
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nConnected to WiFi successfully!");
}

void loop() {
  // Fetch data immediately on startup, then every 'timerDelay' interval
  if ((millis() - lastTime > timerDelay) || lastTime == 0) {
    if (WiFi.status() == WL_CONNECTED) {
      
      // 1. Read Local DHT11 Data
      float localTemp = dht.readTemperature(); // Celcius
      float localHumid = dht.readHumidity();

      // Check if local reading failed
      if (isnan(localTemp) || isnan(localHumid)) {
        Serial.println("[-] Failed to read from DHT11 sensor!");
        localTemp = 0.0; // Fallback to avoid breaking calculation
      }

      // 2. Formulate API URL
      // Using units=metric gives temperature in Celsius
      String url = "http://api.openweathermap.org/data/2.5/weather?q=" + String(city) + 
                   "," + String(countryCode) + "&appid=" + String(apiKey) + "&units=metric";

      HTTPClient http;
      http.begin(url);
      int httpResponseCode = http.GET();

      // 3. Process API Response
      if (httpResponseCode > 0) {
        Serial.println("\n================ WEATHER REPORT ================");
        String payload = http.getString();
        
        // Allocate JsonDocument (Size calculated for standard OWM response)
        JsonDocument doc;
        DeserializationError error = deserializeJson(doc, payload);

        if (!error) {
          // Extract data from JSON response
          const char* cityName = doc["name"];
          float apiTemp = doc["main"]["temp"];
          float apiHumid = doc["main"]["humidity"];
          const char* description = doc["weather"][0]["description"];

          // Calculate differences
          float tempDifference = apiTemp - localTemp;

          // 4. Print results to Serial Monitor
          Serial.printf("City Name:           %s, %s\n", cityName, countryCode);
          Serial.printf("Weather Description: %s\n", description);
          Serial.println("------------------------------------------------");
          Serial.printf("Temperature (API):   %.2f °C\n", apiTemp);
          Serial.printf("Temperature (Local): %.2f °C\n", localTemp);
          Serial.printf("Temp Difference:     %.2f °C\n", tempDifference);
          Serial.println("------------------------------------------------");
          Serial.printf("Humidity (API):      %.1f %%\n", apiHumid);
          Serial.printf("Humidity (Local):    %.1f %%\n", localHumid);
          Serial.println("================================================\n");

        } else {
          Serial.print("[-] JSON Deserialization failed: ");
          Serial.println(error.c_str());
        }
      } else {
        Serial.print("[-] Error code on HTTP request: ");
        Serial.println(httpResponseCode);
      }
      
      // Free resources
      http.end();
      lastTime = millis();
    } else {
      Serial.println("[-] WiFi Disconnected");
    }
  }
}
